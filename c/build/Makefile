	$(MAKE) $(MAKESILENT) -f CMakeFiles/FPV_LiPo_Thermal_Runaway_Guard.dir/build.make CMakeFiles/FPV_LiPo_Thermal_Runaway_Guard.dir/src/ekf.c.i
	$(MAKE) $(MAKESILENT) -f CMakeFiles/compare_b_soc_method.dir/build.make CMakeFiles/compare_b_soc_method.dir/src/ekf.c.i
	$(MAKE) $(MAKESILENT) -f CMakeFiles/compare_c_soh_method.dir/build.make CMakeFiles/compare_c_soh_method.dir/src/ekf.c.i
	$(MAKE) $(MAKESILENT) -f CMakeFiles/compare_d_runaway_alert.dir/build.make CMakeFiles/compare_d_runaway_alert.dir/src/ekf.c.i
	$(MAKE) $(MAKESILENT) -f CMakeFiles/compare_e_power_control.dir/build.make CMakeFiles/compare_e_power_control.dir/src/ekf.c.i
.PHONY : src/ekf.c.i

src/ekf.s: src/ekf.c.s
.PHONY : src/ekf.s

